<?xml version="1.0" encoding="ISO-8859-1"?>

<!DOCTYPE web-app
  PUBLIC "-//Sun Microsystems, Inc.//DTD Web Application 2.2//EN"
  "http://java.sun.com/j2ee/dtds/web-app_2.2.dtd">

<web-app>

  <servlet>
    <servlet-name>
      PortfolioVAR
    </servlet-name>
    <servlet-class>
      com.bcfinancial.servlet.PortfolioVAR
    </servlet-class>
  </servlet> 

  <servlet>
    <servlet-name>
      PortfolioVARChartGenerator
    </servlet-name>
    <servlet-class>
      com.bcfinancial.servlet.PortfolioVARChartGenerator
    </servlet-class>
  </servlet> 

  <servlet>
    <servlet-name>
      MessageHandlerServlet
    </servlet-name>
    <servlet-class>
      com.bcfinancial.servlet.MessageHandlerServlet
    </servlet-class>
  </servlet>

  <servlet-mapping> 
    <servlet-name>PortfolioVAR</servlet-name>
    <url-pattern>/servlet/PortfolioVAR</url-pattern>
  </servlet-mapping>

  <servlet-mapping>
    <servlet-name>PortfolioVARChartGenerator</servlet-name>
    <url-pattern>/servlet/PortfolioVARChartGenerator</url-pattern>
  </servlet-mapping>

  <servlet-mapping>
    <servlet-name>MessageHandlerServlet</servlet-name>
    <url-pattern>/servlet/MessageHandlerServlet</url-pattern>
  </servlet-mapping>

</web-app>
