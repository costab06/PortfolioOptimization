	symbolsList.add("usglx");
	symbolsList.add("jansx");
	symbolsList.add("fdgfx");
	symbolsList.add("oakmx");
	symbolsList.add("ithax");
	symbolsList.add("sblgx");
	//	symbolsList.add("omsox");
	symbolsList.add("phyax");
	symbolsList.add("flpsx");
	symbolsList.add("fagix");
	//	symbolsList.add("pahix");
	symbolsList.add("wbigx");
	//	symbolsList.add("psfax");
	symbolsList.add("fdivx");
	//	symbolsList.add("fdvix");
	symbolsList.add("fmilx");
	symbolsList.add("fresx");
	//	symbolsList.add("pcrrx");
