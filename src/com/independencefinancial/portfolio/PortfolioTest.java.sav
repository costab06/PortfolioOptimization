	//	symbolsList.add("civvx");


	weightsList.add(new Double(.07));
	weightsList.add(new Double(.065));
	weightsList.add(new Double(.06));
	//	weightsList.add(new Double(.055));
	//	weightsList.add(new Double(.055));
	//	weightsList.add(new Double(.05));
	weightsList.add(new Double(.048));
	weightsList.add(new Double(.045));
	weightsList.add(new Double(.04));
	weightsList.add(new Double(.04));
	weightsList.add(new Double(.04));
	weightsList.add(new Double(.04));
	//	weightsList.add(new Double(.04));
	weightsList.add(new Double(.035));
	weightsList.add(new Double(.035));
	weightsList.add(new Double(.035));
	//	weightsList.add(new Double(.035));
	weightsList.add(new Double(.03));
	//	weightsList.add(new Double(.03));
	weightsList.add(new Double(.03));
	//	weightsList.add(new Double(.03));
	weightsList.add(new Double(.022));
	weightsList.add(new Double(.02));
	//	weightsList.add(new Double(.02));
	//	weightsList.add(new Double(.015));
	//	weightsList.add(new Double(.015));


	String[] symbols = new String[symbolsList.size()];
	double weights[] = new double[weightsList.size()];

	for (int i=0;i<symbols.length;i++) {
	    symbols[i]=(String)symbolsList.get(i);
	    weights[i]=((Double)weightsList.get(i)).doubleValue();
	}

	portfolio = new Portfolio(symbols,weights);

	
	double[] returnsList = portfolio.getSortedReturnDistribution(analysis_interval, startAnalysisDate.getTime(),endAnalysisDate.getTime());

	double mean = 0.0;
	double total = 0.0;
	for (int k=0;k<returnsList.length;k++) {
	    total+=returnsList[k];
	}
	mean = total / returnsList.length;
	System.out.println("mean: "+mean);

	int nn = (1 * returnsList.length)/100;
	int nf = (5 * returnsList.length)/100;

	System.out.println("VAR at 99%: "+returnsList[nn]);
	System.out.println("VAR at 95%: "+returnsList[nf]);


        PortfolioTest ptest = new PortfolioTest("Return Distribution",returnsList);
        ptest.pack();
        RefineryUtilities.centerFrameOnScreen(ptest);
        ptest.setVisible(true);
	
    }



    public static void debug(String s) {
	if (DEBUG)
	    System.out.println(s);
    }

}

// This class sorts two numeric objects.
class NumComparator implements Comparator {
   public int compare( Object object1, Object object2 ) {
      return ((Double) object1).compareTo( (Double) object2 );
   }
}

