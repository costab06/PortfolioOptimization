    public static void main(String[] args) {
	PortfolioComputeFarmClient portfolioComputeFarmClient = new PortfolioComputeFarmClient();
	List portfolioCalculatedDataList = portfolioComputeFarmClient.getPortfolioInstances();
	if (portfolioCalculatedDataList == null) {
	    System.out.println("portfolioCalculatedDataList is null");
	} else if (portfolioCalculatedDataList.size() == 0) {
	    System.out.println("portfolioCalculatedDataList is empty");
	} else {
	    
	    // walk the list and display the results

	    for (int i=0;i< portfolioCalculatedDataList.size();i++) {
		PortfolioCalculatedData pcd = (PortfolioCalculatedData) portfolioCalculatedDataList.get(i);
		if (pcd != null) {
		    System.out.println("title:" + pcd.getPortfolioCalculationRequest().getPortfolioName()+" weightedUtility: "+pcd.getWeightedUtility()+" CAGR: "+pcd.getAverageCAGR()+" 99VAR: "+pcd.get99VAR()+" 95VAR: "+pcd.get95VAR());
		} else {
		    System.out.println("portfolioCalculatedData from index "+i+" is null");
		}
	    }
	}
    }
    
    
