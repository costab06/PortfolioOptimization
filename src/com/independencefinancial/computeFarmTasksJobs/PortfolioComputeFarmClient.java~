    public  java.util.List getPortfolioInstances() {
	java.util.List list;
	
	
	
	try {
	    ClasspathServer server = new ClasspathServer();
	    server.start();
	} catch (Exception e) {
	    System.err.println("Exception starting ClasspathServer: "+e);
	    System.exit(1);
	}
	
	    
	    PortfolioOptimizeComputeFarmJob job = new PortfolioOptimizeComputeFarmJob(portfolio,startDate,endDate,timePeriodDays,utilityFunction);
	    
	JobRunnerFactory factory = JobRunnerFactory.newInstance();
	JobRunner jobRunner = factory.newJobRunner(job);
	jobRunner.run();
	list =  job.getPortfolioCalculatedData();
	return list;
    }
    


